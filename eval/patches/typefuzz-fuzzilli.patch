+                    new_types->edge_indices[new_types->count - 1] = i;
+                }
+            }
+        }
+        current++;
+        virgin++;
+    }
+
+    context->found_types += new_types->count;
+    return new_types->count > 0;
+}
+
+void cov_clear_type_bitmap(struct cov_context* context)
+{
+    uint8_t* type_bitmap = (uint8_t*)context->shmem + TYPE_COV_OFFSET;
+    memset(type_bitmap, 0, TYPE_COV_BITMAP_SIZE);
+}
+
+void cov_clear_type_data(struct cov_context* context, uint32_t index)
+{
+    context->found_types -= 1;
+    assert(!edge(context->virgin_type_bits, index));
+    set_edge(context->virgin_type_bits, index);
 }
 
